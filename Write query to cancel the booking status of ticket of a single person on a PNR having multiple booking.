store procedure

CREATE PROCEDURE CancelTicket(
    IN p_pnr VARCHAR(20),
    IN p_date DATE,
    IN p_id INT
)
BEGIN
    UPDATE railway
    SET c_status = 'cancelled'
    WHERE c_pnr = p_pnr
      AND c_date = p_date
      AND c_id = p_id;
END;
